---
import { lotesDisponiveis, lotesVendaveis, LOTES } from '~/data/lotes-data';
import { waHref } from './data';

const disp  = lotesDisponiveis();
const total = lotesVendaveis();
const pct   = Math.round(((total - disp) / total) * 100);

// preview: primeiros 20 lotes vendáveis pra mostrar no grid teaser
const preview = LOTES.filter(l => l.preco > 0).slice(0, 20);
---

<section id="lotes" class="bg-forest py-20 md:py-28 overflow-hidden">
  <div class="mx-auto max-w-7xl px-5 md:px-8">

    <!-- Header -->
    <div class="reveal flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-12">
      <div>
        <p class="eyebrow mb-3 text-gold-soft">Disponibilidade em tempo real</p>
        <h2 class="font-display text-4xl md:text-5xl text-white leading-tight">
          Seu lote está<br />esperando por você.
        </h2>
      </div>
      <div class="flex flex-col gap-2 text-right">
        <p class="text-3xl font-extrabold text-gold">{disp}</p>
        <p class="text-sm text-white/60">lotes disponíveis de {total}</p>
      </div>
    </div>

    <!-- Barra de progresso de vendas -->
    <div class="reveal mb-12">
      <div class="flex justify-between text-xs text-white/50 mb-2">
        <span>{pct}% das unidades já reservadas ou vendidas</span>
        <span>{disp} restantes</span>
      </div>
      <div class="h-2 rounded-full bg-white/10 overflow-hidden">
        <div
          class="h-full bg-gold rounded-full transition-all duration-1000"
          style={`width: ${pct}%`}
        ></div>
      </div>
    </div>

    <!-- Grid teaser visual dos lotes -->
    <div class="reveal-children grid grid-cols-10 gap-1 mb-12 max-w-3xl mx-auto opacity-90" aria-hidden="true">
      {LOTES.filter(l => l.preco > 0).map(l => (
        <div
          title={l.id}
          class={[
            'aspect-square rounded-[3px] text-[6px] font-bold flex items-center justify-center text-white/70',
            l.situacao === 'disponivel' ? 'bg-green-500/70' :
            l.situacao === 'reservado'  ? 'bg-orange-400/80' :
            'bg-white/10'
          ].join(' ')}
        >
          {l.numero}
        </div>
      ))}
    </div>

    <!-- Legenda + CTA -->
    <div class="reveal flex flex-col sm:flex-row items-center justify-center gap-6 mb-10">
      <div class="flex gap-5 text-sm">
        <div class="flex items-center gap-2 text-white/70">
          <span class="w-3 h-3 rounded-full bg-green-500 inline-block"></span> Disponível
        </div>
        <div class="flex items-center gap-2 text-white/70">
          <span class="w-3 h-3 rounded-full bg-orange-400 inline-block"></span> Reservado
        </div>
        <div class="flex items-center gap-2 text-white/70">
          <span class="w-3 h-3 rounded-full bg-white/20 inline-block"></span> Vendido
        </div>
      </div>
    </div>

    <!-- Botão -->
    <div class="reveal text-center">
      <a
        href="/lotes"
        class="inline-flex items-center gap-3 bg-gold text-forest font-bold rounded-full px-8 py-4 text-base hover:bg-gold/90 transition group shadow-lg"
      >
        Ver mapa interativo de lotes
        <svg class="h-4 w-4 transition group-hover:translate-x-1" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M3 8h10M9 4l4 4-4 4" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
      <p class="mt-4 text-xs text-white/40">
        Clique em qualquer lote para ver área, valor e simular o financiamento
      </p>
    </div>

  </div>
</section>
