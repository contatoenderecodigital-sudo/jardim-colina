---
import { LOTES, lotesDisponiveis, lotesReservados, lotesVendidos, lotesVendaveis, brl } from '~/data/lotes-data';
import { WA_NUMBER } from '~/components/jc/data';

const disp    = lotesDisponiveis();
const reserv  = lotesReservados();
const vend    = lotesVendidos();
const total   = lotesVendaveis();
const pctVend = Math.round(((reserv + vend) / total) * 100);

// Serializa apenas o necessário pro cliente (não expõe todos os campos)
const lotesJson = LOTES.map(l => ({
  id: l.id,
  quadra: l.quadra,
  metragem: l.metragem,
  preco: l.preco,
  avista: l.avista,
  parcelas: l.parcelas,
  situacao: l.situacao,
  px: l.pinX,
  py: l.pinY,
}));
---

<!doctype html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Lotes Disponíveis · Loteamento Jardim Colina</title>
  <meta name="description" content="Veja a disponibilidade em tempo real dos lotes do Jardim Colina. Filtre por preço, escolha o seu e fale com a equipe." />
  <meta name="robots" content="index, follow" />
  <link rel="icon" href="/favicon.ico" sizes="any" />
  <meta name="theme-color" content="#15312A" />

  <!-- Leaflet CSS -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.3/leaflet.css" />

  <!-- Fontes -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Playfair+Display:ital,wght@1,600&display=swap" rel="stylesheet" />

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --forest: #15312A;
      --gold:   #C2A15B;
      --paper:  #F5EFE3;
      --ink:    #1A1A1A;
      --green:  #22C55E;
      --orange: #F97316;
      --dark:   #374151;
    }

    html, body { height: 100%; overflow: hidden; font-family: 'Plus Jakarta Sans', sans-serif; background: var(--forest); }

    /* ── TOPBAR ── */
    #topbar {
      position: fixed; top: 0; left: 0; right: 0; z-index: 1000;
      background: var(--forest);
      display: flex; align-items: center; gap: 8px;
      padding: 8px 12px;
      box-shadow: 0 2px 12px rgba(0,0,0,.35);
      min-height: 44px;
    }
    #topbar a { color: var(--gold); font-size: 13px; text-decoration: none; opacity: .8; flex-shrink: 0; white-space: nowrap; }
    #topbar a:hover { opacity: 1; }
    #topbar-title { color: #fff; font-size: 13px; font-weight: 700; flex: 1; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }

    #legend {
      display: flex; gap: 8px; align-items: center; flex-shrink: 0;
    }
    .leg { display: flex; align-items: center; gap: 4px; font-size: 11px; color: rgba(255,255,255,.7); white-space: nowrap; }
    .leg-dot { width: 9px; height: 9px; border-radius: 50%; flex-shrink: 0; }
    .leg-g { background: #16a34a; }
    .leg-o { background: #ea580c; }
    .leg-d { background: #dc2626; }

    #counts {
      display: flex; gap: 6px; flex-shrink: 0;
    }
    .count-chip {
      font-size: 11px; font-weight: 700; border-radius: 20px; padding: 3px 8px;
      color: #fff; white-space: nowrap;
    }
    .cc-g { background: rgba(22,163,74,.25); border: 1px solid rgba(22,163,74,.6); }
    .cc-o { background: rgba(234,88,12,.25); border: 1px solid rgba(234,88,12,.6); }
    .cc-d { background: rgba(220,38,38,.25); border: 1px solid rgba(220,38,38,.6); }

    /* mobile: esconde título e legenda, mantém só os chips */
    @media (max-width: 640px) {
      #topbar-title { display: none; }
      #legend { display: none; }
      #counts { gap: 4px; }
      .count-chip { font-size: 10px; padding: 3px 7px; }
    }

    /* ── MAP ── */
    #map { width: 100%; height: 100vh; padding-top: 44px; background: var(--forest); }

    /* Move zoom control para baixo da barra de filtro */
    .leaflet-control-zoom {
      margin-bottom: 0 !important;
    }
    .leaflet-bottom.leaflet-right {
      margin-bottom: 64px;
      margin-right: 12px;
    }
    .leaflet-control-zoom a {
      font-size: 18px !important;
      line-height: 30px !important;
      width: 32px !important; height: 32px !important;
    }

    /* Pins */
    .lote-marker {
      display: flex; align-items: center; justify-content: center;
      width: 36px; height: 36px; border-radius: 50%;
      font-size: 9px; font-weight: 900; color: #fff;
      border: 2.5px solid rgba(255,255,255,.85);
      cursor: pointer;
      transition: transform .15s, box-shadow .15s;
      box-shadow: 0 2px 8px rgba(0,0,0,.5), 0 0 0 1px rgba(0,0,0,.15);
      line-height: 1;
      text-align: center;
      text-shadow: 0 1px 2px rgba(0,0,0,.4);
      letter-spacing: -.3px;
    }
    .lote-marker:hover {
      transform: scale(1.25);
      z-index: 999 !important;
      box-shadow: 0 4px 16px rgba(0,0,0,.6), 0 0 0 2px rgba(255,255,255,.9);
    }
    .lote-marker.disp  { background: #16a34a; }
    .lote-marker.res   { background: #ea580c; }
    .lote-marker.vend  { background: #dc2626; }
    .lote-marker.bloq  { display: none; }

    /* ── OVERLAY ── */
    #panel-overlay {
      position: fixed; inset: 0; z-index: 1999;
      background: rgba(0,0,0,.55);
      opacity: 0; pointer-events: none;
      transition: opacity .3s;
    }
    #panel-overlay.open { opacity: 1; pointer-events: all; }

    /* ── BOTTOM SHEET (centralizado, todas as telas) ── */
    #panel {
      position: fixed; z-index: 2000;
      bottom: 0; left: 50%;
      transform: translate(-50%, 100%);
      width: 100%; max-width: 460px;
      background: #fff;
      border-radius: 24px 24px 0 0;
      box-shadow: 0 -8px 40px rgba(0,0,0,.35);
      transition: transform .35s cubic-bezier(.25,.46,.45,.94);
      overflow: hidden;
    }
    #panel.open { transform: translate(-50%, 0); }

    .panel-handle {
      width: 36px; height: 4px; background: #e0e0e0; border-radius: 2px;
      margin: 12px auto 0;
    }

    /* ── CABEÇALHO DO PAINEL ── */
    #panel-head {
      padding: 14px 20px 16px;
      border-bottom: 1px solid #f3f3f3;
    }
    #panel-top-row {
      display: flex; align-items: center; justify-content: space-between; margin-bottom: 10px;
    }
    #panel-lote-id { font-size: 11px; font-weight: 800; color: #bbb; text-transform: uppercase; letter-spacing: .1em; }
    #panel-close {
      background: #f5f5f5; border: none; border-radius: 50%;
      width: 28px; height: 28px; cursor: pointer;
      display: flex; align-items: center; justify-content: center;
      font-size: 15px; color: #666; line-height: 1; flex-shrink: 0;
    }
    #panel-close:hover { background: #ebebeb; }

    #panel-status-pill {
      display: inline-block; border-radius: 20px; padding: 5px 14px;
      font-size: 12px; font-weight: 800; text-transform: uppercase; letter-spacing: .05em;
      margin-bottom: 8px;
    }
    .sp-disp { background: #dcfce7; color: #16a34a; }
    .sp-res  { background: #ffedd5; color: #ea580c; }
    .sp-vend { background: #fee2e2; color: #dc2626; }

    #panel-price { font-size: 30px; font-weight: 900; color: var(--forest); line-height: 1; }
    #panel-avista { font-size: 12px; color: #aaa; margin-top: 4px; }

    /* ── INFO PILLS ── */
    .info-pills {
      display: flex; gap: 8px; padding: 12px 20px;
      border-bottom: 1px solid #f3f3f3;
    }
    .info-pill {
      flex: 1; background: #f8f8f8; border-radius: 12px; padding: 10px 10px; text-align: center;
    }
    .pill-label { display: block; font-size: 9px; color: #bbb; text-transform: uppercase; letter-spacing: .05em; margin-bottom: 3px; }
    .pill-val   { display: block; font-size: 13px; font-weight: 800; color: var(--forest); }

    /* ── SIMULADOR (colapsável) ── */
    #simulador-section {
      overflow: hidden; max-height: 0;
      transition: max-height .35s ease, padding .35s;
      padding: 0 20px;
      border-bottom: 1px solid transparent;
    }
    #simulador-section.open {
      max-height: 220px; padding: 14px 20px;
      border-bottom-color: #f3f3f3;
    }
    #simulador-section h4 {
      font-size: 10px; font-weight: 700; text-transform: uppercase;
      letter-spacing: .07em; color: #bbb; margin-bottom: 10px;
    }
    .parc-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 6px; }
    .parc-item { background: #f8f8f8; border-radius: 10px; padding: 8px 6px; text-align: center; }
    .parc-item .pi-key { display: block; font-size: 10px; color: #bbb; }
    .parc-item .pi-val { display: block; font-size: 12px; font-weight: 800; color: var(--forest); margin-top: 2px; }

    /* ── CTAs ── */
    #panel-cta {
      display: grid; grid-template-columns: 1fr 1fr; gap: 10px;
      padding: 14px 20px 28px;
    }
    .btn-reservar {
      display: flex; align-items: center; justify-content: center; gap: 7px;
      background: #25D366; color: #fff; text-decoration: none;
      border: none; border-radius: 14px; padding: 15px 10px;
      font-size: 14px; font-weight: 800; cursor: pointer; font-family: inherit;
      transition: background .2s;
    }
    .btn-reservar:hover { background: #1ebe5d; }
    .btn-simular {
      display: flex; align-items: center; justify-content: center; gap: 7px;
      background: #fff; color: var(--forest);
      border: 2.5px solid var(--forest); border-radius: 14px; padding: 15px 10px;
      font-size: 14px; font-weight: 800; cursor: pointer; font-family: inherit;
      transition: background .2s, color .2s;
    }
    .btn-simular:hover, .btn-simular.active { background: var(--forest); color: #fff; }

    /* filtro de preço */
    #filter-bar {
      position: fixed; bottom: 16px; left: 50%; transform: translateX(-50%);
      z-index: 1000; background: rgba(21,49,42,.95); backdrop-filter: blur(8px);
      border-radius: 50px; padding: 10px 20px;
      display: flex; align-items: center; gap: 10px;
      color: #fff; font-weight: 600;
      box-shadow: 0 4px 20px rgba(0,0,0,.4);
      border: 1px solid rgba(194,161,91,.3);
      white-space: nowrap;
      width: calc(100% - 32px); max-width: 480px;
    }
    #filter-bar label { color: var(--gold); font-size: 12px; flex-shrink: 0; }
    #price-range { flex: 1; min-width: 0; accent-color: var(--gold); }
    #price-label { font-size: 12px; color: rgba(255,255,255,.8); flex-shrink: 0; min-width: 90px; text-align: right; }
  </style>
</head>
<body>

<!-- Topbar -->
<div id="topbar">
  <a href="/">← Início</a>
  <span id="topbar-title">Loteamento Jardim Colina · Lotes em Tempo Real</span>
  <div id="counts">
    <span class="count-chip cc-g" id="cnt-disp">{disp} disponíveis</span>
    <span class="count-chip cc-o" id="cnt-res">{reserv} reservados</span>
    <span class="count-chip cc-d" id="cnt-vend">{vend} vendidos</span>
  </div>
  <div id="legend">
    <div class="leg"><div class="leg-dot leg-g"></div>disponível</div>
    <div class="leg"><div class="leg-dot leg-o"></div>reservado</div>
    <div class="leg"><div class="leg-dot leg-d"></div>indisponível</div>
  </div>
</div>

<!-- Map -->
<div id="map"></div>

<!-- Overlay escuro -->
<div id="panel-overlay"></div>

<!-- Bottom Sheet do lote -->
<div id="panel">
  <div class="panel-handle"></div>

  <div id="panel-head">
    <div id="panel-top-row">
      <span id="panel-lote-id">LOTE —</span>
      <button id="panel-close" aria-label="Fechar">×</button>
    </div>
    <div id="panel-status-pill" class="sp-disp">Disponível</div>
    <div id="panel-price">—</div>
    <div id="panel-avista"></div>
  </div>

  <div class="info-pills">
    <div class="info-pill">
      <span class="pill-label">Área</span>
      <span class="pill-val" id="pill-area">—</span>
    </div>
    <div class="info-pill">
      <span class="pill-label">Entrada</span>
      <span class="pill-val" id="pill-entrada">—</span>
    </div>
    <div class="info-pill">
      <span class="pill-label">À vista</span>
      <span class="pill-val" id="pill-avista">—</span>
    </div>
  </div>

  <div id="simulador-section">
    <h4>Financiamento direto · entrada 20%</h4>
    <div class="parc-grid" id="panel-parcelas"></div>
  </div>

  <div id="panel-cta">
    <a id="panel-wa" href="#" target="_blank" rel="noopener" class="btn-reservar">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
      </svg>
      Reservar
    </a>
    <button class="btn-simular" id="btn-simular">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
        <rect x="2" y="3" width="20" height="18" rx="3"/><path d="M8 12h8M8 16h5M8 8h8"/>
      </svg>
      Simular
    </button>
  </div>
</div>

<!-- Filtro de preço -->
<div id="filter-bar">
  <label>Filtrar até</label>
  <input type="range" id="price-range" min="118000" max="268000" step="5000" value="268000" />
  <span id="price-label">Todos os preços</span>
</div>

<!-- Leaflet JS aqui — garante que L está disponível antes do código do mapa -->
<script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.3/leaflet.js"></script>

<script define:vars={{ lotesJson, WA_NUMBER }}>
  const brl = v => v.toLocaleString('pt-BR', { style: 'currency', currency: 'BRL', maximumFractionDigits: 0 });

  // ── MAP SETUP ──
  const map = L.map('map', {
    crs: L.CRS.Simple,
    minZoom: -2,
    maxZoom: 4,
    zoomControl: false,       // adicionamos manualmente no bottomright
    attributionControl: false,
  });

  // Zoom control no canto inferior direito, acima da barra de filtro
  L.control.zoom({ position: 'bottomright' }).addTo(map);

  const bounds = [[0,0],[500,500]];

  L.imageOverlay(
    '/colina10.webp',
    bounds,
    { opacity: 1, interactive: false }
  ).addTo(map);

  // Trava o pan dentro da imagem (com margem mínima)
  map.setMaxBounds(bounds.pad(0.05));

  // Calcula o zoom mínimo real pra imagem preencher a tela sem fundo atrás
  map.fitBounds(bounds);
  const fitZoom = map.getBoundsZoom(bounds, false);
  map.setMinZoom(fitZoom);
  map.setMaxZoom(fitZoom + 3); // permite zoom in até ver os lotes de perto
  map.setZoom(fitZoom);

  // ── PINS ──
  const markers = {};
  let activeFilter = 268000;

  function statusClass(s) {
    return { disponivel:'disp', reservado:'res', vendido:'vend', bloqueado:'bloq' }[s] || 'bloq';
  }
  function statusLabel(s) {
    return { disponivel:'Disponível', reservado:'Reservado', vendido:'Indisponível', bloqueado:'Área' }[s] || s;
  }

  function createMarkers() {
    lotesJson.forEach(l => {
      if (l.situacao === 'bloqueado' && l.preco === 0) return; // área comum

      const cls = statusClass(l.situacao);
      const num = l.id.split('-')[1];

      const icon = L.divIcon({
        className: '',
        html: `<div class="lote-marker ${cls}" title="${l.id}">${num}</div>`,
        iconSize: [36, 36],
        iconAnchor: [18, 18],
      });

      // Leaflet CRS.Simple: lat = y (inverted), lng = x
      const zOff = cls === 'disp' ? 200 : cls === 'res' ? 150 : 100;
      const marker = L.marker([l.py, l.px], { icon, zIndexOffset: zOff });

      marker.on('click', () => openPanel(l));
      marker.addTo(map);
      markers[l.id] = { marker, lote: l };
    });
  }

  createMarkers();

  // ── FILTER ──
  const priceRange = document.getElementById('price-range');
  const priceLabel = document.getElementById('price-label');

  priceRange.addEventListener('input', () => {
    activeFilter = parseInt(priceRange.value);
    priceLabel.textContent = activeFilter >= 268000 ? 'Todos os preços' : `até ${brl(activeFilter)}`;
    Object.values(markers).forEach(({ marker, lote }) => {
      const visible = lote.preco <= activeFilter || lote.preco === 0 || lote.situacao !== 'disponivel';
      marker.setOpacity(visible ? 1 : 0.15);
    });
  });

  // ── PANEL ──
  const panel   = document.getElementById('panel');
  const overlay = document.getElementById('panel-overlay');
  const simSec  = document.getElementById('simulador-section');
  const btnSim  = document.getElementById('btn-simular');
  let simOpen   = false;

  function closePanel() {
    panel.classList.remove('open');
    overlay.classList.remove('open');
    simSec.classList.remove('open');
    btnSim.classList.remove('active');
    simOpen = false;
  }

  function openPanel(l) {
    document.getElementById('panel-lote-id').textContent = 'LOTE ' + l.id;
    document.getElementById('panel-price').textContent   = l.preco > 0 ? brl(l.preco) : '—';
    document.getElementById('panel-avista').textContent  = l.avista > 0 ? `À vista: ${brl(l.avista)} (5% desc.)` : '';

    const pill = document.getElementById('panel-status-pill');
    const pillClass = { disponivel:'sp-disp', reservado:'sp-res', vendido:'sp-vend' }[l.situacao] || 'sp-vend';
    pill.className = pillClass;
    pill.textContent = statusLabel(l.situacao);

    document.getElementById('pill-area').textContent    = l.metragem > 0 ? l.metragem.toFixed(0) + ' m²' : '—';
    document.getElementById('pill-entrada').textContent = l.preco > 0 ? brl(l.preco * 0.2) : '—';
    document.getElementById('pill-avista').textContent  = l.avista > 0 ? brl(l.avista) : '—';

    const keys = ['12x','18x','24x','36x','48x','60x','72x'];
    document.getElementById('panel-parcelas').innerHTML = keys.map(k =>
      `<div class="parc-item"><span class="pi-key">${k}</span><span class="pi-val">${l.parcelas[k] > 0 ? brl(l.parcelas[k]) : '—'}</span></div>`
    ).join('');

    const isDisp = l.situacao === 'disponivel';
    const waBtn  = document.getElementById('panel-wa');
    const msg = encodeURIComponent(`Olá! Tenho interesse no *Lote ${l.id}* do Jardim Colina${l.preco > 0 ? ` (${brl(l.preco)})` : ''}. Pode me enviar mais informações?`);
    waBtn.href = `https://wa.me/${WA_NUMBER}?text=${msg}`;
    waBtn.style.opacity = isDisp || l.situacao === 'reservado' ? '1' : '.5';
    waBtn.style.pointerEvents = isDisp || l.situacao === 'reservado' ? '' : 'none';

    // fecha simulador ao abrir novo lote
    simSec.classList.remove('open');
    btnSim.classList.remove('active');
    simOpen = false;

    panel.classList.add('open');
    overlay.classList.add('open');
  }

  btnSim.addEventListener('click', () => {
    simOpen = !simOpen;
    simSec.classList.toggle('open', simOpen);
    btnSim.classList.toggle('active', simOpen);
  });

  document.getElementById('panel-close').addEventListener('click', closePanel);
  overlay.addEventListener('click', closePanel);
  map.on('click', closePanel);
</script>
</body>
</html>
