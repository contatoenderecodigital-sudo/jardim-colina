---
import { LOTES } from '~/data/lotes-data';

const SB_URL = import.meta.env.PUBLIC_SUPABASE_URL ?? '';
const SB_KEY = import.meta.env.PUBLIC_SUPABASE_ANON_KEY ?? '';

const dispStatic  = LOTES.filter(l => l.situacao === 'disponivel').length;
const totalStatic = LOTES.length;
const pctStatic   = Math.round(((totalStatic - dispStatic) / totalStatic) * 100);
const restStatic  = 100 - pctStatic;

const pins = LOTES.map(l => ({
  id:   l.id,
  sit:  l.situacao,
  left: (l.pinX / 500 * 100).toFixed(2),
  top:  ((500 - l.pinY) / 500 * 100).toFixed(2),
}));

function pinColor(sit: string) {
  if (sit === 'disponivel') return '#22c55e';
  if (sit === 'reservado')  return '#facc15';
  return '#ef4444';
}
---

<section id="lotes" class="py-20 md:py-28" style="background:linear-gradient(to bottom,#0f2318 0%,#15312a 100%);">
  <div class="mx-auto max-w-7xl px-5 md:px-8">

    <div class="reveal grid grid-cols-1 md:grid-cols-2 gap-10 md:gap-16 items-center">

      <!-- Coluna esquerda -->
      <div class="flex flex-col gap-7">

        <!-- Eyebrow com dot pulsante -->
        <div class="flex items-center gap-2">
          <span class="relative flex h-2 w-2 flex-shrink-0">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-green-500"></span>
          </span>
          <p class="eyebrow text-gold-soft tracking-widest">Disponibilidade em tempo real</p>
        </div>

        <!-- Título + parágrafo -->
        <div>
          <h2 class="font-display text-4xl md:text-5xl text-white leading-tight">
            Seu lote está<br />esperando por você.
          </h2>
          <p class="mt-4 text-white/55 text-[0.95rem] leading-relaxed">
            <span id="lt-total">{totalStatic}</span> lotes no total. Os melhores saem primeiro,
            veja o que ainda está livre antes que esgote.
          </p>
        </div>

        <!-- Stats: dois números -->
        <div class="flex items-stretch gap-6">
          <div>
            <p class="text-[10px] text-white/35 uppercase tracking-widest mb-2">Disponíveis</p>
            <p id="lt-disp" class="text-5xl font-black text-green-400 leading-none tabular-nums">{dispStatic}</p>
          </div>
          <div class="w-px bg-white/10 self-stretch flex-shrink-0 mx-1"></div>
          <div>
            <p class="text-[10px] text-white/35 uppercase tracking-widest mb-2">Já foram</p>
            <p id="lt-sold" class="text-5xl font-black text-red-400 leading-none tabular-nums">{totalStatic - dispStatic}</p>
          </div>
        </div>

        <!-- Barra com labels nos dois lados -->
        <div>
          <div class="flex justify-between items-baseline mb-2">
            <span class="text-xs text-white/45">
              <span id="lt-pct">{pctStatic}</span>% já escolhidos
            </span>
            <span class="text-xs font-bold text-gold-soft">
              restam <span id="lt-pct-rest">{restStatic}</span>%
            </span>
          </div>
          <div class="h-2 rounded-full overflow-hidden" style="background:rgba(255,255,255,0.08);">
            <div
              id="lt-bar"
              class="h-full rounded-full transition-all duration-700"
              style={`width:${pctStatic}%;background:linear-gradient(90deg,#d8be86,#c2a15b);`}
            ></div>
          </div>
        </div>

        <!-- Legenda -->
        <div class="flex items-center gap-5 text-[10px] font-bold tracking-widest flex-wrap">
          <div class="flex items-center gap-2 text-white/50">
            <span class="w-2 h-2 rounded-full bg-green-500 flex-shrink-0"></span> Disponível
          </div>
          <div class="flex items-center gap-2 text-white/50">
            <span class="w-2 h-2 rounded-full bg-yellow-400 flex-shrink-0"></span> Reservado
          </div>
          <div class="flex items-center gap-2 text-white/50">
            <span class="w-2 h-2 rounded-full bg-red-500 flex-shrink-0"></span> Indisponível
          </div>
        </div>

      </div>

      <!-- Coluna direita: mapa -->
      <div class="w-full">
        <!-- Wrapper com aspect-ratio: ancora badge + imagem + botão -->
        <div class="relative w-full" style="aspect-ratio:1/1;">

          <!-- Imagem com overflow-hidden (rounded corners + clip dos pins) -->
          <div class="absolute inset-0 overflow-hidden rounded-2xl">
            <img
              src="/colina10.webp"
              alt="Vista aérea do Loteamento Jardim Colina com disponibilidade em tempo real"
              class="w-full h-full object-cover"
              loading="lazy"
            />
            <!-- Pins -->
            {pins.map(p => (
              <span
                data-pin-id={p.id}
                title={p.id}
                class="absolute -translate-x-1/2 -translate-y-1/2 rounded-full ring-1 ring-white/30"
                style={`left:${p.left}%;top:${p.top}%;width:6px;height:6px;background:${pinColor(p.sit)};`}
              />
            ))}
          </div>

          <!-- Botão na borda inferior -->
          <div class="absolute bottom-5 left-0 right-0 flex justify-center" style="z-index:10;">
            <a
              href="/lotes"
              class="inline-flex items-center gap-2 bg-gold text-forest font-bold rounded-full px-7 py-3 text-sm shadow-lg hover:bg-gold/90 transition whitespace-nowrap"
            >
              Explorar mapa interativo
              <svg class="h-4 w-4" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M3 8h10M9 4l4 4-4 4" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
          </div>

        </div>
      </div>

    </div>

    <p class="reveal text-center mt-8 text-xs text-white/25">
      Clique em qualquer lote para ver área, valor e simular o financiamento
    </p>

  </div>
</section>

<div id="lt-cfg" data-url={SB_URL} data-key={SB_KEY} hidden></div>

<script>
  (async () => {
    const cfg    = document.getElementById('lt-cfg') as HTMLElement | null;
    const SB_URL = cfg?.dataset.url;
    const SB_KEY = cfg?.dataset.key;

    function pinBg(sit: string): string {
      if (sit === 'disponivel') return '#22c55e';
      if (sit === 'reservado')  return '#facc15';
      return '#ef4444';
    }

    if (!SB_URL || !SB_KEY) return;

    try {
      const [baseRes, sbRes] = await Promise.all([
        fetch('/lotes-data.json'),
        fetch(`${SB_URL}/rest/v1/lote_status?select=id,situacao`, {
          headers: { 'apikey': SB_KEY, 'Authorization': `Bearer ${SB_KEY}` }
        })
      ]);
      if (!baseRes.ok || !sbRes.ok) return;

      const base: any[]      = await baseRes.json();
      const overrides: any[] = await sbRes.json();

      const ovMap: Record<string, string> = {};
      overrides.forEach((o: any) => { ovMap[o.id] = o.situacao; });

      const merged = base.map((l: any) => ({ ...l, situacao: ovMap[l.id] ?? l.situacao }));

      document.querySelectorAll<HTMLElement>('[data-pin-id]').forEach(pin => {
        const id = pin.dataset.pinId!;
        if (ovMap[id]) pin.style.background = pinBg(ovMap[id]);
      });

      const disp  = merged.filter((l: any) => l.situacao === 'disponivel').length;
      const total = merged.length;
      const pct   = Math.round(((total - disp) / total) * 100);
      const rest  = 100 - pct;

      const set = (id: string, v: string | number) => {
        const el = document.getElementById(id);
        if (el) el.textContent = String(v);
      };
      set('lt-disp',     disp);
      set('lt-total',    total);
      set('lt-sold',     total - disp);
      set('lt-pct',      pct);
      set('lt-pct-rest', rest);

      const bar = document.getElementById('lt-bar') as HTMLElement | null;
      if (bar) bar.style.width = pct + '%';

    } catch (_) {}
  })();
</script>
