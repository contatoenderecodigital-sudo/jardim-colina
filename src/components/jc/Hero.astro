---
import { Image } from 'astro:assets';
import heroImg from '~/assets/jardimcolina/hero-pordosol.png';
import logoTransp from '~/assets/jardimcolina/brand/santafe-logo-transp.png';
import { waHref, PRECO_LOTE } from '~/components/jc/data';
---

<section id="top" class="relative h-[100svh] min-h-[640px] w-full overflow-hidden bg-forest">

  <!-- Fundo: imagem como fallback -->
  <Image
    src={heroImg}
    alt="Vista aérea do Loteamento Jardim Colina ao pôr do sol, com o skyline de Xanxerê ao fundo"
    widths={[768, 1280, 1920]}
    sizes="100vw"
    format="webp"
    quality={72}
    loading="eager"
    fetchpriority="high"
    class="absolute inset-0 h-full w-full object-cover"
  />

  <!-- Vídeo drone (sobrepõe imagem no desktop quando existir) -->
  <video
    class="absolute inset-0 h-full w-full object-cover"
    autoplay muted loop playsinline preload="auto"
    poster="/video/hero-poster.jpg"
    aria-hidden="true"
  >
    <source src="/video/hero-mobile.mp4" media="(max-width: 767px)" type="video/mp4" />
    <source src="/video/hero.mp4" type="video/mp4" />
  </video>

  <!-- Overlay: mais denso à esquerda, abertura à direita para os renders aparecerem -->
  <div class="absolute inset-0" style="background: linear-gradient(110deg, rgba(12,30,24,0.90) 0%, rgba(18,42,34,0.72) 45%, rgba(21,49,42,0.30) 100%);"></div>

  <!-- Barra de metadados — abaixo do header fixo (~68px) -->
  <div class="absolute inset-x-0 top-0 z-10 pt-[68px]">
    <div
      class="mx-auto flex max-w-7xl items-center justify-between px-5 py-2.5 md:px-8"
      style="border-bottom: 1px solid rgba(255,255,255,0.1);"
    >
      <span class="hero-meta">Xanxerê · SC</span>
      <span class="hero-meta">Lançamento</span>
    </div>
  </div>

  <!-- Layout principal: texto ancorado no canto inferior esquerdo -->
  <div class="absolute inset-0 z-10 flex flex-col justify-end px-6 pb-24 md:px-14 md:pb-28">

    <!-- Bloco de texto -->
    <div class="hero-text-block max-w-[680px]">
      <div class="mb-4 md:mb-6" style="display:inline-flex;align-items:center;background:rgba(255,255,255,0.95);border-radius:999px;padding:7px 18px;box-shadow:0 4px 20px rgba(0,0,0,0.25);">
        <Image src={logoTransp} alt="Santafé Imobiliária" width={200} height={60} style="height:26px;width:auto;display:block;object-fit:contain;" />
      </div>

      <h1 class="font-display leading-[1.05] text-white" style="font-size: clamp(2.2rem, 7.5vw, 6.5rem);">
        <span class="sr-only">Loteamento Jardim Colina em Xanxerê SC. </span>A cidade no<br />
        <em class="gold-grad" style="font-style: italic; font-family: 'Playfair Display', Georgia, serif; font-weight: 700;">
          seu horizonte.
        </em>
      </h1>

      <p class="mt-4 text-[0.92rem] leading-relaxed text-white/70 md:mt-6 md:text-[1.05rem] md:leading-[2]">
        Lotes de 360m²{PRECO_LOTE ? <> a partir de <span class="font-semibold text-gold-soft">{PRECO_LOTE}</span></> : ''} no coração de Xanxerê.
        Em até 72x direto com a incorporadora.
      </p>

      <div class="mt-6 flex flex-wrap items-center gap-3 md:mt-8">
        <a href={waHref()} target="_blank" rel="noopener noreferrer" class="btn-wa">
          Ver os lotes e valores
        </a>
        <a href="#conceito" class="btn-ghost inline-flex items-center gap-2">
          Ver o projeto
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    </div>

  </div>

  <!-- Indicador de scroll -->
  <div class="hero-scroll absolute bottom-7 left-1/2 z-10 -translate-x-1/2 flex flex-col items-center gap-1.5" aria-hidden="true">
    <span class="text-[9px] font-semibold uppercase tracking-[0.22em] text-white/35">Role para explorar</span>
    <svg xmlns="http://www.w3.org/2000/svg" class="hero-chevron h-4 w-4 text-white/35" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
    </svg>
  </div>
</section>
