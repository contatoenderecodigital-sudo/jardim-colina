---
import JCLayout from '~/layouts/JCLayout.astro';
import Footer from '~/components/jc/Footer.astro';
import { CONTATO, waHref } from '~/components/jc/data';

// Link pro Drive de materiais (trocar pela URL real quando criar a pasta)
const DRIVE_URL = '#';
const WA_PARCERIA = waHref('Olá! Sou corretor parceiro e quero acesso aos materiais do Jardim Colina.');
---

<JCLayout
  title="Área do Corretor · Loteamento Jardim Colina"
  description="Materiais exclusivos para corretores parceiros do Loteamento Jardim Colina. Imagens, textos prontos e tabela espelho."
  noindex={true}
>
  <main id="main" class="bg-paper-2">

    <!-- Cabeçalho -->
    <div class="bg-forest px-5 py-5 text-center">
      <a href="/" class="inline-block text-gold/80 text-sm hover:text-gold transition">
        ← Voltar ao site
      </a>
    </div>

    <div class="mx-auto max-w-4xl px-5 py-16 md:py-24 md:px-8">

      <!-- Título -->
      <div class="mb-14 text-center">
        <p class="eyebrow mb-3">Parceria</p>
        <h1 class="font-display text-4xl leading-tight text-ink md:text-5xl">
          Área do Corretor
        </h1>
        <p class="mt-5 max-w-xl mx-auto text-lg text-ink-soft">
          Materiais exclusivos para corretores credenciados. Use nas suas redes, no WhatsApp e nas suas apresentações.
        </p>
      </div>

      <!-- Cards de materiais -->
      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">

        <!-- Imagens -->
        <div class="rounded-[20px] border border-ink/10 bg-white p-6">
          <div class="mb-4 text-forest">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
          </div>
          <h2 class="font-display text-xl text-ink mb-2">Imagens</h2>
          <p class="text-sm text-ink-soft mb-5">Renders, fotos drone e materiais gráficos sem marca d'água, prontos para usar.</p>
          <a
            href={DRIVE_URL}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 text-sm font-semibold text-forest hover:text-bronze transition"
          >
            Baixar no Drive
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
            </svg>
          </a>
        </div>

        <!-- Textos prontos -->
        <div class="rounded-[20px] border border-ink/10 bg-white p-6">
          <div class="mb-4 text-forest">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
          </div>
          <h2 class="font-display text-xl text-ink mb-2">Textos prontos</h2>
          <p class="text-sm text-ink-soft mb-5">Legendas para Instagram, mensagens para WhatsApp e copy de anúncio. É só copiar e adaptar.</p>
          <a
            href={DRIVE_URL}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 text-sm font-semibold text-forest hover:text-bronze transition"
          >
            Acessar no Drive
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
            </svg>
          </a>
        </div>

        <!-- Tabela espelho -->
        <div class="rounded-[20px] border border-ink/10 bg-white p-6">
          <div class="mb-4 text-forest">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 10h18M3 14h18m-9-4v8m-7 0h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z" />
            </svg>
          </div>
          <h2 class="font-display text-xl text-ink mb-2">Tabela espelho</h2>
          <p class="text-sm text-ink-soft mb-5">Disponibilidade e valores atualizados dos lotes para sua apresentação ao cliente.</p>
          <a
            href={DRIVE_URL}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 text-sm font-semibold text-forest hover:text-bronze transition"
          >
            Ver tabela
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
            </svg>
          </a>
        </div>

      </div>

      <!-- Bloco de contato -->
      <div class="mt-14 rounded-[24px] bg-forest px-8 py-10 text-center text-white">
        <p class="eyebrow mb-3 text-gold-soft">Parceria</p>
        <h2 class="font-display text-3xl text-white mb-3">Quer ser corretor parceiro?</h2>
        <p class="text-white/75 max-w-lg mx-auto mb-8">
          Fale com a equipe da Santafé e solicite credenciamento para vender os lotes do Jardim Colina.
        </p>
        <div class="flex flex-col sm:flex-row gap-3 justify-center">
          <a
            href={WA_PARCERIA}
            target="_blank"
            rel="noopener noreferrer"
            class="btn-wa inline-flex items-center justify-center gap-2"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            Falar pelo WhatsApp
          </a>
          <a
            href={`tel:${CONTATO.telefoneComercial.replace(/\D/g,'')}`}
            class="inline-flex items-center justify-center gap-2 rounded-full border border-white/30 px-7 py-3.5 text-sm font-semibold text-white transition hover:bg-white/10"
          >
            {CONTATO.telefoneComercial}
          </a>
        </div>
      </div>

    </div>

    <Footer />
  </main>
</JCLayout>
