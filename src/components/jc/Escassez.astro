---
import { LOTES_TOTAL, LOTES_RESERVADOS, waHref } from '~/components/jc/data';

// Só aparece quando o número REAL de reservados for preenchido (LOTES_RESERVADOS > 0).
// Escassez verdadeira: nunca número inventado.
const reservados = LOTES_RESERVADOS;
const restantes = Math.max(0, LOTES_TOTAL - reservados);
const pct = LOTES_TOTAL > 0 ? Math.min(100, Math.round((reservados / LOTES_TOTAL) * 100)) : 0;

const waReserva = waHref('Oi! Quero garantir um lote do Jardim Colina antes que esgote. Pode me passar os disponíveis?');
---

{
  reservados > 0 && (
    <section class="bg-forest text-white" style="background:radial-gradient(ellipse 100% 60% at 50% 0%, #2a6050 0%, #15312a 70%);">
      <div class="reveal mx-auto max-w-3xl px-5 pb-20 pt-12 text-center md:pb-24 md:pt-16">
        <p class="eyebrow mb-3">Lançamento · 1ª fase</p>
        <h2 class="text-2xl leading-tight text-white sm:text-3xl">
          Dos {LOTES_TOTAL} lotes, {reservados} já foram reservados.
        </h2>

        <div class="mt-7 h-3 w-full overflow-hidden rounded-full bg-white/15">
          <div
            class="h-full rounded-full bg-gradient-to-r from-gold-soft to-gold"
            style={`width:${pct}%`}
          />
        </div>
        <p class="mt-3 text-sm text-white/70">
          {restantes}{' '}{restantes === 1 ? 'lote ainda disponível' : 'lotes ainda disponíveis'} nesta fase.
        </p>
        <p class="mt-2 text-xs text-white/45">
          Atualizado em junho de 2026 · consulte a disponibilidade dos lotes de esquina.
        </p>

        <a href={waReserva} target="_blank" rel="noopener noreferrer" class="btn-wa mt-8">
          Garantir o meu lote
        </a>
      </div>
    </section>
  )
}
