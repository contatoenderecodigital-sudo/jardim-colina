---
import JCLayout from '~/layouts/JCLayout.astro';
---

<JCLayout title="Página não encontrada · Loteamento Jardim Colina">
  <main id="main" class="flex min-h-[80vh] items-center bg-forest text-white">
    <div class="mx-auto max-w-md px-6 text-center">
      <p class="font-display text-7xl text-gold">404</p>
      <p class="mt-6 text-2xl">Não encontramos esta página.</p>
      <p class="mt-3 text-white/75">Volte para a página inicial e conheça o Jardim Colina.</p>
      <a href="/" class="btn-gold-outline mt-8 !text-white">Voltar ao início</a>
    </div>
  </main>
</JCLayout>
