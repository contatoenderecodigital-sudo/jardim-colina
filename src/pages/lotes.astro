---
import { LOTES, lotesDisponiveis, lotesReservados, lotesVendidos, lotesVendaveis, brl } from '~/data/lotes-data';
import { WA_NUMBER } from '~/components/jc/data';

const disp    = lotesDisponiveis();
const reserv  = lotesReservados();
const vend    = lotesVendidos();
const total   = lotesVendaveis();
const pctVend = Math.round(((reserv + vend) / total) * 100);

// Serializa apenas o necessário pro cliente (não expõe todos os campos)
const lotesJson = LOTES.map(l => ({
  id: l.id,
  quadra: l.quadra,
  metragem: l.metragem,
  preco: l.preco,
  avista: l.avista,
  parcelas: l.parcelas,
  situacao: l.situacao,
  px: l.pinX,
  py: l.pinY,
}));
---

<!doctype html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Lotes Disponíveis · Loteamento Jardim Colina</title>
  <meta name="description" content="Veja a disponibilidade em tempo real dos lotes do Jardim Colina. Filtre por preço, escolha o seu e fale com a equipe." />
  <meta name="robots" content="index, follow" />
  <link rel="icon" href="/favicon.ico" sizes="any" />
  <meta name="theme-color" content="#15312A" />

  <!-- Leaflet CSS -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.3/leaflet.css" />

  <!-- Fontes -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Playfair+Display:ital,wght@1,600&display=swap" rel="stylesheet" />

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --forest: #15312A;
      --gold:   #C2A15B;
      --paper:  #F5EFE3;
      --ink:    #1A1A1A;
      --green:  #22C55E;
      --orange: #F97316;
      --dark:   #374151;
    }

    html, body { height: 100%; overflow: hidden; font-family: 'Plus Jakarta Sans', sans-serif; background: var(--forest); }

    /* ── TOPBAR ── */
    #topbar {
      position: fixed; top: 0; left: 0; right: 0; z-index: 1000;
      background: var(--forest);
      display: flex; align-items: center; gap: 12px;
      padding: 10px 16px;
      box-shadow: 0 2px 12px rgba(0,0,0,.35);
    }
    #topbar a { color: var(--gold); font-size: 13px; text-decoration: none; opacity: .8; flex-shrink: 0; }
    #topbar a:hover { opacity: 1; }
    #topbar-title { color: #fff; font-size: 14px; font-weight: 700; flex: 1; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }

    #legend {
      display: flex; gap: 10px; align-items: center; flex-shrink: 0;
    }
    .leg { display: flex; align-items: center; gap: 4px; font-size: 11px; color: rgba(255,255,255,.7); }
    .leg-dot { width: 10px; height: 10px; border-radius: 50%; }
    .leg-g { background: var(--green); }
    .leg-o { background: var(--orange); }
    .leg-d { background: var(--dark); }

    #counts {
      display: flex; gap: 8px; flex-shrink: 0;
    }
    .count-chip {
      font-size: 11px; font-weight: 700; border-radius: 20px; padding: 2px 8px;
      color: #fff;
    }
    .cc-g { background: rgba(34,197,94,.25); border: 1px solid rgba(34,197,94,.5); }
    .cc-o { background: rgba(249,115,22,.25); border: 1px solid rgba(249,115,22,.5); }
    .cc-d { background: rgba(55,65,81,.35); border: 1px solid rgba(55,65,81,.6); }

    /* ── MAP ── */
    #map { width: 100%; height: 100vh; padding-top: 48px; }

    /* Pins */
    .lote-marker {
      display: flex; align-items: center; justify-content: center;
      width: 22px; height: 22px; border-radius: 50%;
      font-size: 7px; font-weight: 800; color: #fff;
      border: 2px solid rgba(255,255,255,.6);
      cursor: pointer;
      transition: transform .15s, box-shadow .15s;
      box-shadow: 0 1px 4px rgba(0,0,0,.4);
      line-height: 1;
      text-align: center;
    }
    .lote-marker:hover { transform: scale(1.3); z-index: 999 !important; }
    .lote-marker.disp  { background: var(--green); }
    .lote-marker.res   { background: var(--orange); }
    .lote-marker.vend  { background: var(--dark); }
    .lote-marker.bloq  { background: #374151; opacity: .4; pointer-events: none; }

    /* ── POPUP (sidebar no mobile → painel lateral no desktop) ── */
    #panel {
      position: fixed; z-index: 2000;
      bottom: 0; left: 0; right: 0;
      background: #fff;
      border-radius: 20px 20px 0 0;
      padding: 20px 20px 32px;
      box-shadow: 0 -4px 24px rgba(0,0,0,.25);
      transform: translateY(100%);
      transition: transform .3s ease;
      max-height: 80vh;
      overflow-y: auto;
    }
    #panel.open { transform: translateY(0); }

    @media (min-width: 640px) {
      #panel {
        bottom: auto; top: 60px; right: 16px; left: auto;
        width: 340px; border-radius: 16px;
        transform: translateX(110%);
        max-height: calc(100vh - 80px);
      }
      #panel.open { transform: translateX(0); }
    }

    #panel-close {
      position: absolute; top: 12px; right: 14px;
      background: none; border: none; font-size: 20px; cursor: pointer; color: #888;
      line-height: 1;
    }

    #panel-lote  { font-size: 13px; font-weight: 700; color: var(--forest); text-transform: uppercase; letter-spacing: .08em; margin-bottom: 2px; }
    #panel-title { font-size: 22px; font-weight: 800; color: var(--ink); }
    #panel-preco { font-size: 20px; font-weight: 800; color: var(--forest); margin-top: 2px; }
    #panel-avista{ font-size: 12px; color: #888; margin-bottom: 12px; }

    .panel-row { display: flex; justify-content: space-between; align-items: center; padding: 7px 0; border-bottom: 1px solid #f0f0f0; font-size: 13px; }
    .panel-row:last-of-type { border-bottom: none; }
    .panel-label { color: #888; }
    .panel-val   { font-weight: 700; color: var(--ink); }

    #panel-parc { margin-top: 14px; }
    #panel-parc h4 { font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: .06em; color: #aaa; margin-bottom: 8px; }
    .parc-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 6px; }
    .parc-item { background: #f8f8f8; border-radius: 8px; padding: 7px 10px; }
    .parc-item span:first-child { display: block; font-size: 11px; color: #aaa; }
    .parc-item span:last-child  { display: block; font-size: 14px; font-weight: 700; color: var(--forest); }

    #panel-cta {
      margin-top: 16px;
      display: flex; flex-direction: column; gap: 8px;
    }
    .btn-wa-lote {
      display: flex; align-items: center; justify-content: center; gap: 8px;
      background: #25D366; color: #fff;
      border: none; border-radius: 50px; padding: 13px 20px;
      font-size: 15px; font-weight: 700; cursor: pointer;
      text-decoration: none;
    }
    .btn-wa-lote:hover { background: #1ebe5d; }

    #panel-status-badge {
      display: inline-flex; align-items: center; gap: 6px;
      border-radius: 20px; padding: 4px 10px;
      font-size: 12px; font-weight: 700;
      margin-bottom: 12px;
    }
    .badge-disp { background: #dcfce7; color: #16a34a; }
    .badge-res  { background: #ffedd5; color: #ea580c; }
    .badge-vend { background: #f3f4f6; color: #374151; }

    /* filtro de preço */
    #filter-bar {
      position: fixed; bottom: 16px; left: 50%; transform: translateX(-50%);
      z-index: 1000; background: rgba(21,49,42,.92); backdrop-filter: blur(8px);
      border-radius: 50px; padding: 8px 16px;
      display: flex; align-items: center; gap: 10px;
      color: #fff; font-size: 13px; font-weight: 600;
      box-shadow: 0 4px 20px rgba(0,0,0,.4);
      border: 1px solid rgba(194,161,91,.3);
    }
    #filter-bar label { white-space: nowrap; color: var(--gold); font-size: 11px; }
    #price-range { width: 120px; accent-color: var(--gold); }
    #price-label { font-size: 11px; color: rgba(255,255,255,.7); }
  </style>
</head>
<body>

<!-- Topbar -->
<div id="topbar">
  <a href="/">← Início</a>
  <span id="topbar-title">Loteamento Jardim Colina · Lotes em Tempo Real</span>
  <div id="counts">
    <span class="count-chip cc-g" id="cnt-disp">{disp} disponíveis</span>
    <span class="count-chip cc-o" id="cnt-res">{reserv} reservados</span>
    <span class="count-chip cc-d" id="cnt-vend">{vend} vendidos</span>
  </div>
  <div id="legend">
    <div class="leg"><div class="leg-dot leg-g"></div>disponível</div>
    <div class="leg"><div class="leg-dot leg-o"></div>reservado</div>
    <div class="leg"><div class="leg-dot leg-d"></div>vendido</div>
  </div>
</div>

<!-- Map -->
<div id="map"></div>

<!-- Painel lateral do lote -->
<div id="panel">
  <button id="panel-close" aria-label="Fechar">×</button>
  <div id="panel-lote">LOTE</div>
  <div id="panel-title">Jardim Colina</div>
  <div id="panel-preco"></div>
  <div id="panel-avista"></div>
  <div id="panel-status-badge"></div>

  <div id="panel-info"></div>

  <div id="panel-parc">
    <h4>Financiamento direto — entrada 20%</h4>
    <div class="parc-grid" id="panel-parcelas"></div>
  </div>

  <div id="panel-cta">
    <a id="panel-wa" href="#" target="_blank" rel="noopener" class="btn-wa-lote">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
      </svg>
      Quero esse lote
    </a>
  </div>
</div>

<!-- Filtro de preço -->
<div id="filter-bar">
  <label>Filtrar até</label>
  <input type="range" id="price-range" min="118000" max="268000" step="5000" value="268000" />
  <span id="price-label">Todos os preços</span>
</div>

<!-- Leaflet JS aqui — garante que L está disponível antes do código do mapa -->
<script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.3/leaflet.js"></script>

<script define:vars={{ lotesJson, WA_NUMBER }}>
  const brl = v => v.toLocaleString('pt-BR', { style: 'currency', currency: 'BRL', maximumFractionDigits: 0 });

  // ── MAP SETUP ──
  const map = L.map('map', {
    crs: L.CRS.Simple,
    minZoom: 0,
    maxZoom: 4,
    zoomControl: true,
    attributionControl: false,
  });

  const bounds = [[0,0],[500,500]];
  // Usa a mesma imagem do UMMETRO (já mapeada para o sistema de coordenadas 0-500)
  L.imageOverlay(
    'https://loteamentojardimcolina.com.br/colina10.webp',
    bounds,
    { opacity: 1, interactive: false }
  ).addTo(map);

  map.fitBounds(bounds);
  map.setView([280, 240], 1.5);

  // ── PINS ──
  const markers = {};
  let activeFilter = 268000;

  function statusClass(s) {
    return { disponivel:'disp', reservado:'res', vendido:'vend', bloqueado:'bloq' }[s] || 'bloq';
  }
  function statusLabel(s) {
    return { disponivel:'Disponível', reservado:'Reservado', vendido:'Vendido', bloqueado:'Área' }[s] || s;
  }

  function createMarkers() {
    lotesJson.forEach(l => {
      if (l.situacao === 'bloqueado' && l.preco === 0) return; // área comum

      const cls = statusClass(l.situacao);
      const num = l.id.split('-')[1];

      const icon = L.divIcon({
        className: '',
        html: `<div class="lote-marker ${cls}" title="${l.id}">${num}</div>`,
        iconSize: [22, 22],
        iconAnchor: [11, 11],
      });

      // Leaflet CRS.Simple: lat = y (inverted), lng = x
      const marker = L.marker([l.py, l.px], { icon, zIndexOffset: cls === 'disp' ? 100 : 50 });

      marker.on('click', () => openPanel(l));
      marker.addTo(map);
      markers[l.id] = { marker, lote: l };
    });
  }

  createMarkers();

  // ── FILTER ──
  const priceRange = document.getElementById('price-range');
  const priceLabel = document.getElementById('price-label');

  priceRange.addEventListener('input', () => {
    activeFilter = parseInt(priceRange.value);
    priceLabel.textContent = activeFilter >= 268000 ? 'Todos os preços' : `até ${brl(activeFilter)}`;
    Object.values(markers).forEach(({ marker, lote }) => {
      const visible = lote.preco <= activeFilter || lote.preco === 0 || lote.situacao !== 'disponivel';
      marker.setOpacity(visible ? 1 : 0.15);
    });
  });

  // ── PANEL ──
  const panel = document.getElementById('panel');

  function openPanel(l) {
    document.getElementById('panel-lote').textContent = 'LOTE ' + l.id;
    document.getElementById('panel-title').textContent = 'Jardim Colina · Quadra ' + l.quadra;
    document.getElementById('panel-preco').textContent = l.preco > 0 ? brl(l.preco) : '—';
    document.getElementById('panel-avista').textContent = l.avista > 0 ? `À vista: ${brl(l.avista)} (5% desc.)` : '';

    const badge = document.getElementById('panel-status-badge');
    const bc = { disponivel:'badge-disp', reservado:'badge-res', vendido:'badge-vend' }[l.situacao] || 'badge-vend';
    badge.className = 'panel-status-badge ' + bc;
    badge.textContent = statusLabel(l.situacao);

    document.getElementById('panel-info').innerHTML = `
      <div class="panel-row"><span class="panel-label">Área</span><span class="panel-val">${l.metragem > 0 ? l.metragem.toFixed(2).replace('.',',') + ' m²' : '—'}</span></div>
      <div class="panel-row"><span class="panel-label">Entrada (20%)</span><span class="panel-val">${l.preco > 0 ? brl(l.preco * 0.2) : '—'}</span></div>
    `;

    const keys = ['12x','18x','24x','36x','48x','60x','72x'];
    document.getElementById('panel-parcelas').innerHTML = keys.map(k =>
      `<div class="parc-item"><span>${k}</span><span>${l.parcelas[k] > 0 ? brl(l.parcelas[k]) : '—'}</span></div>`
    ).join('');

    const msg = encodeURIComponent(`Olá! Tenho interesse no *Lote ${l.id}* do Jardim Colina${l.preco > 0 ? ` (${brl(l.preco)})` : ''}. Pode me enviar mais informações?`);
    document.getElementById('panel-wa').href = `https://wa.me/${WA_NUMBER}?text=${msg}`;

    panel.classList.add('open');
  }

  document.getElementById('panel-close').addEventListener('click', () => {
    panel.classList.remove('open');
  });

  // Fechar ao clicar no mapa
  map.on('click', () => panel.classList.remove('open'));
</script>
</body>
</html>
