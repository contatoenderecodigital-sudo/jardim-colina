---
import JCLayout from '~/layouts/JCLayout.astro';
import Footer from '~/components/jc/Footer.astro';
import { WA_NUMBER, WA_MESSAGE, waHref } from '~/components/jc/data';
---

<JCLayout
  title="Recebemos seu contato · Loteamento Jardim Colina"
  description="Obrigado pelo interesse no Loteamento Jardim Colina. Um consultor Santafé entrará em contato pelo WhatsApp."
  noindex={true}
>
  <main id="main" class="flex min-h-screen flex-col bg-paper-2">

    <!-- Cabeçalho simples -->
    <div class="bg-forest px-5 py-5 text-center">
      <a href="/" class="inline-block text-gold/80 text-sm hover:text-gold transition">
        ← Voltar ao site
      </a>
    </div>

    <!-- Conteúdo principal -->
    <div class="mx-auto flex w-full max-w-lg flex-1 flex-col items-center justify-center px-5 py-20 text-center">

      <!-- Ícone de check -->
      <div class="mb-8 flex h-20 w-20 items-center justify-center rounded-full bg-forest/10">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 text-forest" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
        </svg>
      </div>

      <h1 class="font-display text-4xl leading-tight text-ink">
        Recebemos seu contato!
      </h1>

      <p class="mt-5 text-lg text-ink-soft">
        Um consultor da Santafé vai falar com você pelo WhatsApp com os detalhes, os lotes disponíveis e as condições de pagamento.
      </p>

      <p class="mt-3 text-base text-ink-mute">
        Se o WhatsApp não abriu automaticamente, toque no botão abaixo.
      </p>

      <!-- Botão WhatsApp (lê a URL personalizada do sessionStorage; fallback pro padrão) -->
      <a
        id="btn-wa"
        href={waHref(WA_MESSAGE)}
        target="_blank"
        rel="noopener noreferrer"
        class="btn-wa mt-10 inline-flex w-full max-w-xs items-center justify-center gap-3 text-base"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        Falar pelo WhatsApp
      </a>

      <a href="/" class="mt-6 text-sm text-ink-mute underline-offset-2 hover:underline">
        Voltar ao site do Jardim Colina
      </a>
    </div>

    <Footer />
  </main>

  <!-- Lê a URL personalizada do sessionStorage (gerada pelo formulário com nome/objetivo/pagamento) -->
  <script define:vars={{ fallback: waHref(WA_MESSAGE) }}>
    (() => {
      const btn = document.getElementById('btn-wa');
      if (!btn) return;
      const stored = sessionStorage.getItem('jc_wa');
      if (stored) {
        btn.href = stored;
        sessionStorage.removeItem('jc_wa');
        // abre automaticamente se chegou pelo formulário
        window.open(stored, '_blank');
      }
    })();
  </script>
</JCLayout>
