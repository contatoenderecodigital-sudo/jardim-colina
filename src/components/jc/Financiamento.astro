---
import { Image } from 'astro:assets';
import aerea from '~/assets/jardimcolina/financiamento-fundo72x.jpg';
import { waHref, PRECO_LOTE, PRECO_M2, LOTES_TOTAL, LOTES_RESERVADOS } from '~/components/jc/data';

const SB_URL = import.meta.env.PUBLIC_SUPABASE_URL ?? '';
const SB_KEY = import.meta.env.PUBLIC_SUPABASE_ANON_KEY ?? '';

const waSimular = waHref(
  'Olá! Vi o site do Loteamento Jardim Colina e quero receber a tabela completa de preços e fazer a simulação, sem compromisso.'
);

const reservados = LOTES_RESERVADOS;
const restantes = Math.max(0, LOTES_TOTAL - reservados);
const pct = LOTES_TOTAL > 0 ? Math.min(100, Math.round((reservados / LOTES_TOTAL) * 100)) : 0;
---

<section id="financiamento" class="relative overflow-hidden bg-forest">
  <Image
    src={aerea}
    alt="Vista aérea do Loteamento Jardim Colina"
    widths={[768, 1280, 1920]}
    sizes="100vw"
    format="webp"
    quality={70}
    loading="lazy"
    class="ken-burns absolute inset-0 h-full w-full object-cover"
  />
  <div class="absolute inset-0" style="background: rgba(21,49,42,0.82);"></div>

  <div class="relative z-10 mx-auto max-w-7xl px-5 pb-24 pt-14 md:px-8 md:pb-32 md:pt-18">
    <div class="reveal reveal-zoom mx-auto max-w-2xl rounded-[28px] border border-gold/50 bg-forest/40 px-7 py-12 text-center backdrop-blur-[2px] md:px-12 md:py-14">
      <p class="eyebrow mb-4">Financiamento</p>
      <h2 class="text-2xl leading-tight text-white sm:text-3xl">
        Financiamento direto com a incorporadora
      </h2>

      {
        PRECO_LOTE ? (
          <>
            <p class="mt-7 text-base uppercase tracking-[0.18em] text-white/65">Lotes a partir de</p>
            <p class="font-sans font-bold text-gold whitespace-nowrap" style="font-size:clamp(2.4rem,11vw,4.5rem);">{PRECO_LOTE}</p>
            {PRECO_M2 ? <p class="mt-2 text-sm text-white/60">{PRECO_M2} por m² · lote de 360m²</p> : ''}
            <p class="mt-3 font-sans font-semibold text-base text-gold-soft sm:text-xl">em até 72x, direto com a incorporadora</p>
          </>
        ) : (
          <p class="mt-6 font-display text-7xl text-gold md:text-8xl">Até 72x</p>
        )
      }

      <p class="mx-auto mt-6 max-w-md text-[0.95rem] leading-[1.75] text-white/80">
        Condições facilitadas. Você fala direto com quem realiza o empreendimento e monta um plano que cabe no seu
        momento.
      </p>
      <a href={waSimular} target="_blank" rel="noopener noreferrer" class="btn-wa mt-9">
        Receber a tabela de preços
      </a>
    </div>

    {reservados > 0 && (
      <div class="reveal mx-auto mt-14 max-w-xl text-center">
        <p class="mb-4 text-sm font-semibold uppercase tracking-[0.18em] text-white/50">
          Disponibilidade · 1ª fase
        </p>
        <div class="lotes-bar-wrap h-3 w-full overflow-hidden rounded-full bg-white/15">
          <div
            id="lotes-fill"
            class="lotes-fill h-full rounded-full"
            data-pct={pct}
            style="width:0%;background:linear-gradient(90deg,#d8be86,#c2a15b);"
          />
        </div>
        <p class="mt-5 flex items-baseline justify-center gap-2 text-lg text-white/70">
          <span id="fin-disp" class="font-bold text-2xl" style="color:#f87171;">{restantes}</span>
          <span>lotes disponíveis de</span>
          <span id="fin-total" class="font-bold text-2xl text-gold-soft">{LOTES_TOTAL}</span>
        </p>
      </div>
    )}
  </div>
</section>
<div id="fin-cfg" data-url={SB_URL} data-key={SB_KEY} data-total={LOTES_TOTAL} hidden></div>

<style>
.lotes-fill {
  transition: width 1.6s cubic-bezier(.25,.46,.45,.94) 0.3s;
  position: relative;
  overflow: hidden;
}
.lotes-fill::after {
  content: '';
  position: absolute;
  top: 0; bottom: 0;
  left: -100%;
  width: 55%;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.35), transparent);
  transition: none;
}
.lotes-bar-wrap:hover .lotes-fill::after {
  animation: bar-shimmer 0.75s ease forwards;
}
@keyframes bar-shimmer {
  from { left: -55%; }
  to   { left: 120%; }
}
</style>

<script is:inline>
(function () {
  var fill = document.getElementById('lotes-fill');
  if (!fill) return;
  var pct = fill.dataset.pct;
  var io = new IntersectionObserver(function (entries) {
    entries.forEach(function (e) {
      if (e.isIntersecting) {
        fill.style.width = pct + '%';
        io.disconnect();
      }
    });
  }, { threshold: 0.5 });
  io.observe(fill);
})();
</script>

<script>
(async () => {
  const cfg    = document.getElementById('fin-cfg') as HTMLElement | null;
  const SB_URL = cfg?.dataset.url;
  const SB_KEY = cfg?.dataset.key;
  const total  = Number(cfg?.dataset.total ?? 0);
  if (!SB_URL || !SB_KEY || !total) return;
  try {
    const [baseRes, sbRes] = await Promise.all([
      fetch('/lotes-data.json'),
      fetch(`${SB_URL}/rest/v1/lote_status?select=id,situacao`, {
        headers: { 'apikey': SB_KEY, 'Authorization': `Bearer ${SB_KEY}` }
      })
    ]);
    if (!baseRes.ok || !sbRes.ok) return;
    const base: any[]      = await baseRes.json();
    const overrides: any[] = await sbRes.json();
    const ovMap: Record<string, string> = {};
    overrides.forEach((o: any) => { ovMap[o.id] = o.situacao; });
    const merged = base.map((l: any) => ({ ...l, situacao: ovMap[l.id] ?? l.situacao }));
    const disp = merged.filter((l: any) => l.situacao === 'disponivel').length;
    const pct  = Math.min(100, Math.round(((total - disp) / total) * 100));
    const dispEl  = document.getElementById('fin-disp');
    const totalEl = document.getElementById('fin-total');
    const fill    = document.getElementById('lotes-fill') as HTMLElement | null;
    if (dispEl)  dispEl.textContent  = String(disp);
    if (totalEl) totalEl.textContent = String(total);
    if (fill) { fill.dataset.pct = String(pct); fill.style.width = pct + '%'; }
  } catch (_) {}
})();
</script>
