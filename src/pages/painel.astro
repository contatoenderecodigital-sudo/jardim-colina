---
const SUPABASE_URL = import.meta.env.PUBLIC_SUPABASE_URL ?? '';
const SUPABASE_KEY = import.meta.env.PUBLIC_SUPABASE_ANON_KEY ?? '';
---

<!doctype html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Admin · Loteamento Jardim Colina</title>
  <meta name="robots" content="noindex, nofollow" />
  <link rel="icon" href="/favicon.ico" sizes="any" />

  <!-- Supabase JS via CDN -->
  <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2/dist/umd/supabase.js"></script>

  <!-- Fontes -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet" />

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --forest: #15312A; --gold: #C2A15B; --paper: #F5EFE3;
      --green: #22C55E; --orange: #F97316; --dark: #374151; --red: #EF4444;
    }
    body { font-family: 'Plus Jakarta Sans', sans-serif; background: #f0f2f0; min-height: 100vh; }

    /* ── LOGIN ── */
    #login-screen {
      display: flex; align-items: center; justify-content: center;
      min-height: 100vh; background: var(--forest); padding: 20px;
    }
    #login-box {
      background: #fff; border-radius: 20px; padding: 40px 32px;
      width: 100%; max-width: 380px; text-align: center;
    }
    #login-box h1 { font-size: 22px; font-weight: 800; color: var(--forest); margin-bottom: 4px; }
    #login-box p  { font-size: 13px; color: #888; margin-bottom: 28px; }
    .field { text-align: left; margin-bottom: 16px; }
    .field label { display: block; font-size: 12px; font-weight: 700; color: #555; margin-bottom: 5px; text-transform: uppercase; letter-spacing: .05em; }
    .field input {
      width: 100%; border: 1.5px solid #e0e0e0; border-radius: 10px;
      padding: 11px 14px; font-size: 15px; font-family: inherit; outline: none;
      transition: border-color .2s;
    }
    .field input:focus { border-color: var(--forest); }
    #btn-login {
      width: 100%; background: var(--forest); color: #fff;
      border: none; border-radius: 50px; padding: 14px;
      font-size: 15px; font-weight: 700; cursor: pointer; font-family: inherit;
      transition: background .2s;
    }
    #btn-login:hover { background: #1f4a3a; }
    #btn-login:disabled { opacity: .5; cursor: default; }
    #login-error { margin-top: 12px; font-size: 13px; color: var(--red); display: none; }

    /* ── DASHBOARD ── */
    #dashboard { display: none; }

    header {
      background: var(--forest); color: #fff;
      padding: 14px 24px; display: flex; align-items: center; gap: 16px;
    }
    header h1 { font-size: 16px; font-weight: 700; flex: 1; }
    header span { font-size: 12px; color: rgba(255,255,255,.55); }
    .role-badge {
      font-size: 11px; font-weight: 700; padding: 3px 10px; border-radius: 20px;
      background: rgba(255,255,255,.15); color: rgba(255,255,255,.9);
    }
    .role-badge.gestor { background: var(--gold); color: var(--forest); }
    #btn-logout {
      background: none; border: 1px solid rgba(255,255,255,.3); color: rgba(255,255,255,.8);
      border-radius: 20px; padding: 5px 14px; font-size: 12px; cursor: pointer; font-family: inherit;
    }

    .container { max-width: 1100px; margin: 0 auto; padding: 24px 16px; }

    /* stats */
    .stats { display: grid; grid-template-columns: repeat(auto-fit, minmax(140px, 1fr)); gap: 12px; margin-bottom: 28px; }
    .stat-card { background: #fff; border-radius: 14px; padding: 16px 20px; box-shadow: 0 1px 4px rgba(0,0,0,.07); }
    .stat-card .num { font-size: 28px; font-weight: 800; }
    .stat-card .lbl { font-size: 12px; color: #888; margin-top: 2px; }
    .sc-g .num { color: var(--green); }
    .sc-o .num { color: var(--orange); }
    .sc-d .num { color: var(--dark); }
    .sc-t .num { color: var(--forest); }

    /* search */
    #search-bar { display: flex; gap: 10px; margin-bottom: 20px; flex-wrap: wrap; }
    #search-input {
      flex: 1; min-width: 180px; border: 1.5px solid #ddd; border-radius: 10px;
      padding: 9px 14px; font-size: 14px; font-family: inherit; outline: none;
    }
    #search-input:focus { border-color: var(--forest); }
    .filter-btn {
      border: 1.5px solid #ddd; border-radius: 20px; padding: 8px 14px;
      font-size: 12px; font-weight: 700; cursor: pointer; background: #fff;
      font-family: inherit; transition: all .2s;
    }
    .filter-btn.active { border-color: var(--forest); background: var(--forest); color: #fff; }

    /* tabela */
    .table-wrap { background: #fff; border-radius: 16px; overflow: hidden; box-shadow: 0 1px 4px rgba(0,0,0,.07); }
    table { width: 100%; border-collapse: collapse; font-size: 13px; }
    th { background: var(--forest); color: rgba(255,255,255,.8); font-size: 11px; font-weight: 700;
         text-transform: uppercase; letter-spacing: .05em; padding: 10px 14px; text-align: left; }
    td { padding: 10px 14px; border-bottom: 1px solid #f3f3f3; vertical-align: middle; }
    tr:last-child td { border-bottom: none; }
    tr:hover td { background: #fafafa; }

    .badge {
      display: inline-flex; align-items: center; gap: 4px;
      border-radius: 20px; padding: 3px 9px;
      font-size: 11px; font-weight: 700;
    }
    .badge-disp { background: #dcfce7; color: #16a34a; }
    .badge-res  { background: #ffedd5; color: #ea580c; }
    .badge-vend { background: #f3f4f6; color: #374151; }
    .badge-bloq { background: #f3f4f6; color: #9ca3af; font-size: 10px; }

    .status-select {
      border: 1.5px solid #e0e0e0; border-radius: 8px; padding: 5px 8px;
      font-size: 12px; font-family: inherit; cursor: pointer; outline: none;
      background: #fff;
    }
    .status-select:focus { border-color: var(--forest); }

    .save-btn {
      background: var(--forest); color: #fff;
      border: none; border-radius: 8px; padding: 5px 12px;
      font-size: 12px; font-weight: 700; cursor: pointer; font-family: inherit;
      transition: opacity .2s;
    }
    .save-btn:hover { opacity: .85; }
    .save-btn:disabled { opacity: .4; cursor: default; }
    .save-btn.saved { background: var(--green); }

    /* msg de config */
    #config-warning {
      background: #fffbeb; border: 1px solid #fcd34d; border-radius: 12px;
      padding: 14px 18px; font-size: 13px; color: #92400e; margin-bottom: 20px;
      display: none;
    }
    #config-warning code { background: #fef3c7; padding: 1px 5px; border-radius: 4px; font-size: 12px; }
  </style>
</head>
<body>

<!-- Login -->
<div id="login-screen">
  <div id="login-box">
    <h1>Jardim Colina</h1>
    <p>Painel administrativo · acesso restrito</p>
    <div class="field">
      <label>Email</label>
      <input type="email" id="email" placeholder="seu@email.com" autocomplete="email" />
    </div>
    <div class="field">
      <label>Senha</label>
      <input type="password" id="senha" placeholder="••••••••" autocomplete="current-password" />
    </div>
    <button id="btn-login">Entrar</button>
    <div id="login-error"></div>
  </div>
</div>

<!-- Dashboard -->
<div id="dashboard">
  <header>
    <h1>Painel · Lotes em Tempo Real</h1>
    <span id="user-email"></span>
    <span id="role-badge" class="role-badge" style="display:none"></span>
    <button id="btn-logout">Sair</button>
  </header>

  <div class="container">
    <div id="config-warning">
      <strong>Supabase não configurado.</strong> Os dados mostrados são estáticos. Para ativar atualizações em tempo real, defina as variáveis de ambiente <code>PUBLIC_SUPABASE_URL</code> e <code>PUBLIC_SUPABASE_ANON_KEY</code> no painel do Vercel.
    </div>

    <div class="stats" id="stats-grid"></div>

    <div id="search-bar">
      <input type="text" id="search-input" placeholder="Buscar lote (ex: B-22)..." />
      <button class="filter-btn active" data-filter="todos">Todos</button>
      <button class="filter-btn" data-filter="disponivel">Disponíveis</button>
      <button class="filter-btn" data-filter="reservado">Reservados</button>
      <button class="filter-btn" data-filter="vendido">Vendidos</button>
    </div>

    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Lote</th>
            <th>Quadra</th>
            <th>Área</th>
            <th>Preço</th>
            <th>Status atual</th>
            <th>Alterar para</th>
            <th></th>
          </tr>
        </thead>
        <tbody id="lotes-tbody"></tbody>
      </table>
    </div>
  </div>
</div>

<script define:vars={{ SUPABASE_URL, SUPABASE_KEY }}>
  const hasSupabase = !!(SUPABASE_URL && SUPABASE_KEY);
  let supabaseClient = null;

  if (hasSupabase && window.supabase) {
    supabaseClient = window.supabase.createClient(SUPABASE_URL, SUPABASE_KEY);
  }

  // ── DADOS LOCAIS (fallback sem Supabase) ────────────────────────────────────
  // Importados via inline JSON (Astro injeta ao build)
  // Por ora, carregamos via fetch do endpoint local
  let lotesData = [];

  async function carregarLotes() {
    if (hasSupabase && supabaseClient) {
      const { data, error } = await supabaseClient.from('lotes').select('*').order('id');
      if (!error && data) return data;
    }
    // Fallback: dados estáticos do arquivo gerado ao build
    const r = await fetch('/lotes-data.json');
    if (r.ok) return r.json();
    return [];
  }

  // ── AUTH ─────────────────────────────────────────────────────────────────────
  const DEMO_PASSWORD = 'jardimcolina2026'; // senha demo local (sem Supabase)
  const DEMO_EMAIL    = 'admin@jardimcolina.com.br';

  const loginScreen  = document.getElementById('login-screen');
  const dashboard    = document.getElementById('dashboard');
  const btnLogin     = document.getElementById('btn-login');
  const loginError   = document.getElementById('login-error');
  const emailInput   = document.getElementById('email');
  const senhaInput   = document.getElementById('senha');

  // Tecla Enter no form
  senhaInput.addEventListener('keydown', e => { if (e.key === 'Enter') btnLogin.click(); });

  btnLogin.addEventListener('click', async () => {
    const email = emailInput.value.trim();
    const senha = senhaInput.value;
    btnLogin.disabled = true;
    loginError.style.display = 'none';

    if (hasSupabase && supabaseClient) {
      const { data, error } = await supabaseClient.auth.signInWithPassword({ email, password: senha });
      if (error) {
        loginError.textContent = 'Email ou senha incorretos.';
        loginError.style.display = 'block';
        btnLogin.disabled = false;
        return;
      }
      const role = data.user?.user_metadata?.role ?? 'funcionario';
      mostrarDashboard(email, role);
    } else {
      // Modo demo local (sem Supabase)
      if (email === DEMO_EMAIL && senha === DEMO_PASSWORD) {
        mostrarDashboard(email, 'gestor');
      } else {
        loginError.textContent = 'Credenciais inválidas. (Modo demo: use o email e senha fornecidos pela equipe)';
        loginError.style.display = 'block';
        btnLogin.disabled = false;
      }
    }
  });

  document.getElementById('btn-logout').addEventListener('click', async () => {
    if (supabaseClient) await supabaseClient.auth.signOut();
    loginScreen.style.display = 'flex';
    dashboard.style.display   = 'none';
    emailInput.value = '';
    senhaInput.value = '';
  });

  async function mostrarDashboard(email, role = 'funcionario') {
    loginScreen.style.display = 'none';
    dashboard.style.display   = 'block';
    document.getElementById('user-email').textContent = email;

    const badge = document.getElementById('role-badge');
    badge.style.display = 'inline-block';
    if (role === 'gestor') {
      badge.textContent = 'Gestor';
      badge.classList.add('gestor');
    } else {
      badge.textContent = 'Funcionário';
    }

    if (!hasSupabase) {
      document.getElementById('config-warning').style.display = 'block';
    }

    lotesData = await carregarLotes();
    renderTabela(lotesData);
    renderStats(lotesData);
  }

  // ── TABELA ───────────────────────────────────────────────────────────────────
  const brl = v => v > 0 ? v.toLocaleString('pt-BR', { style: 'currency', currency: 'BRL', maximumFractionDigits: 0 }) : '—';
  const m2  = v => v > 0 ? v.toFixed(2).replace('.', ',') + ' m²' : '—';

  const BADGE = {
    disponivel: '<span class="badge badge-disp">● Disponível</span>',
    reservado:  '<span class="badge badge-res">● Reservado</span>',
    vendido:    '<span class="badge badge-vend">● Vendido</span>',
    bloqueado:  '<span class="badge badge-bloq">Área</span>',
  };

  let currentFilter = 'todos';

  function renderTabela(lotes) {
    const query  = document.getElementById('search-input').value.toLowerCase();
    const tbody  = document.getElementById('lotes-tbody');

    const filtered = lotes.filter(l => {
      if (l.situacao === 'bloqueado' && l.preco === 0) return false; // oculta áreas comuns
      const matchFilter = currentFilter === 'todos' || l.situacao === currentFilter;
      const matchSearch = !query || l.id.toLowerCase().includes(query) || l.quadra.toLowerCase().includes(query);
      return matchFilter && matchSearch;
    });

    tbody.innerHTML = filtered.map(l => `
      <tr data-id="${l.id}">
        <td><strong>${l.id}</strong></td>
        <td>${l.quadra}</td>
        <td>${m2(l.metragem)}</td>
        <td>${brl(l.preco)}</td>
        <td>${BADGE[l.situacao] || l.situacao}</td>
        <td>
          <select class="status-select" data-id="${l.id}" data-current="${l.situacao}">
            <option value="disponivel" ${l.situacao==='disponivel'?'selected':''}>Disponível</option>
            <option value="reservado"  ${l.situacao==='reservado' ?'selected':''}>Reservado</option>
            <option value="vendido"    ${l.situacao==='vendido'   ?'selected':''}>Vendido</option>
          </select>
        </td>
        <td>
          <button class="save-btn" data-id="${l.id}">Salvar</button>
        </td>
      </tr>
    `).join('');

    // eventos
    tbody.querySelectorAll('.save-btn').forEach(btn => {
      btn.addEventListener('click', async () => {
        const id  = btn.dataset.id;
        const sel = tbody.querySelector(`.status-select[data-id="${id}"]`);
        const novoStatus = sel.value;
        btn.disabled = true;
        btn.textContent = '…';

        const ok = await atualizarStatus(id, novoStatus);
        if (ok) {
          btn.textContent = '✓';
          btn.classList.add('saved');
          // atualiza local
          const lote = lotesData.find(l => l.id === id);
          if (lote) lote.situacao = novoStatus;
          renderStats(lotesData);
          // restore
          setTimeout(() => { btn.textContent = 'Salvar'; btn.classList.remove('saved'); btn.disabled = false; }, 1800);
        } else {
          btn.textContent = 'Erro';
          btn.disabled = false;
        }
      });
    });
  }

  async function atualizarStatus(id, status) {
    if (hasSupabase && supabaseClient) {
      const { error } = await supabaseClient.from('lotes').update({ situacao: status }).eq('id', id);
      return !error;
    }
    // sem Supabase: apenas atualiza local (demo)
    return true;
  }

  function renderStats(lotes) {
    const vend = lotes.filter(l => l.preco > 0);
    const disp = vend.filter(l => l.situacao === 'disponivel').length;
    const res  = vend.filter(l => l.situacao === 'reservado').length;
    const v    = vend.filter(l => l.situacao === 'vendido').length;
    document.getElementById('stats-grid').innerHTML = `
      <div class="stat-card sc-t"><div class="num">${vend.length}</div><div class="lbl">Total vendáveis</div></div>
      <div class="stat-card sc-g"><div class="num">${disp}</div><div class="lbl">Disponíveis</div></div>
      <div class="stat-card sc-o"><div class="num">${res}</div><div class="lbl">Reservados</div></div>
      <div class="stat-card sc-d"><div class="num">${v}</div><div class="lbl">Vendidos</div></div>
    `;
  }

  // ── FILTROS ───────────────────────────────────────────────────────────────────
  document.querySelectorAll('.filter-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      currentFilter = btn.dataset.filter;
      renderTabela(lotesData);
    });
  });

  document.getElementById('search-input').addEventListener('input', () => renderTabela(lotesData));

  // ── SESSÃO PERSISTENTE ────────────────────────────────────────────────────────
  if (hasSupabase && supabaseClient) {
    supabaseClient.auth.getSession().then(({ data: { session } }) => {
      if (session) {
        const role = session.user?.user_metadata?.role ?? 'funcionario';
        mostrarDashboard(session.user.email, role);
      }
    });
  }
</script>
</body>
</html>
